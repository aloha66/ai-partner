{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-partner.local/schema/workflow-event.schema.json",
  "title": "WorkflowEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "event_id",
    "source",
    "run_id",
    "workflow_state",
    "timestamp",
    "code_context_allowed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ai-partner.workflow-event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^evt_[A-Za-z0-9._:-]+$"
    },
    "source": {
      "type": "string",
      "enum": ["cli", "codex-wrapper", "demo-script", "claude-hook", "codex-hook"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^run_[A-Za-z0-9._:-]+$"
    },
    "workflow_state": {
      "type": "string",
      "enum": ["idle", "running", "reading", "editing", "waiting", "error", "done"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "message": {
      "type": "string",
      "maxLength": 160,
      "pattern": "^[^\\r\\n]*$"
    },
    "card_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[^\\r\\n]*$"
    },
    "context_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\r\\n]*$"
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "description", "status"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["command", "tool"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^auth_[A-Za-z0-9._:-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[^\\r\\n]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[^\\r\\n]*$"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "allowed", "denied"]
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "code_context_allowed": {
      "const": false
    }
  }
}
