{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-partner.local/schema/animation-intent.schema.json",
  "title": "AnimationIntent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "body", "bubble", "queued"],
  "properties": {
    "schemaVersion": {
      "const": "ai-partner.animation-intent.v1"
    },
    "body": {
      "$ref": "#/$defs/bodyIntent"
    },
    "bubble": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "text", "priority"],
          "properties": {
            "state": {
              "type": "string",
              "enum": ["idle", "running", "reading", "editing", "waiting", "error", "done"]
            },
            "text": {
              "type": "string",
              "maxLength": 160,
              "pattern": "^[^\\r\\n]*$"
            },
            "priority": {
              "type": "string",
              "enum": ["normal", "high"]
            }
          }
        }
      ]
    },
    "queued": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["animation", "reason", "expiresAt"],
        "properties": {
          "animation": {
            "$ref": "#/$defs/animationRef"
          },
          "reason": {
            "type": "string",
            "enum": ["physical-override"]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "$defs": {
    "animationRef": {
      "type": "string",
      "pattern": "^(workflow|physical|legacy)\\.[a-z0-9-]+$"
    },
    "bodyIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["animation", "procedural", "loop", "source"],
      "properties": {
        "animation": {
          "$ref": "#/$defs/animationRef"
        },
        "procedural": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": ["shake", "squash", "float", "drop"]
          }
        },
        "loop": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/frameSource"
        }
      }
    },
    "frameSource": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "row", "frameCount", "fps"],
          "properties": {
            "kind": {
              "const": "petdex-row"
            },
            "row": {
              "type": "string",
              "enum": [
                "idle",
                "running-right",
                "running-left",
                "waving",
                "jumping",
                "failed",
                "waiting",
                "running",
                "review"
              ]
            },
            "frameCount": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "fps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 24
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "frames", "fps"],
          "properties": {
            "kind": {
              "const": "png-sequence"
            },
            "frames": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "fps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 24
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reason"],
          "properties": {
            "kind": {
              "const": "missing"
            },
            "reason": {
              "const": "animation-unavailable"
            }
          }
        }
      ]
    }
  }
}
