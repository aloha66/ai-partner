{
  "name": "ai-partner",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @ai-partner/frontend dev",
    "tauri:dev": "pnpm exec tauri dev --config src-tauri/tauri.conf.json",
    "build": "pnpm --filter @ai-partner/frontend build",
    "test": "pnpm -r test",
    "test:contracts": "pnpm --filter @ai-partner/contracts test",
    "test:frontend": "pnpm --filter @ai-partner/frontend test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
