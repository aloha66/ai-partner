{
  "name": "ai-partner",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @ai-partner/frontend dev",
    "tauri:dev": "pnpm exec tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "pnpm exec tauri build --config src-tauri/tauri.conf.json",
    "tauri:build:app": "pnpm exec tauri build --config src-tauri/tauri.conf.json --bundles app",
    "package:dmg": "pnpm run smoke:dmg:preflight && pnpm run tauri:build:app && node scripts/package-macos-dmg.mjs",
    "smoke:dmg:preflight": "node scripts/check-macos-package-config.mjs",
    "build": "pnpm --filter @ai-partner/frontend build",
    "debug:discover": "pnpm --filter @ai-partner/debug-cli debug:discover",
    "debug:send": "pnpm --filter @ai-partner/debug-cli debug:send",
    "debug:sequence": "pnpm --filter @ai-partner/debug-cli debug:sequence",
    "codex:wrap": "pnpm --filter @ai-partner/codex-wrapper codex:wrap",
    "test": "pnpm -r test",
    "test:typecheck": "pnpm -r --if-present typecheck",
    "test:contracts": "pnpm --filter @ai-partner/contracts test",
    "test:codex-wrapper": "pnpm --filter @ai-partner/codex-wrapper test",
    "test:debug-cli": "pnpm --filter @ai-partner/debug-cli test",
    "test:frontend": "pnpm --filter @ai-partner/frontend test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
